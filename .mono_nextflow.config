// Nextflow config file for rnaseq on DAIC.
// Put this file in the launch directory: the directory in which you `nextflow run`.
// See https://www.nextflow.io/docs/latest/config.html for more info.
dag.overwrite = true
params {
  slurm_partition = System.getenv('SLURM_PARTITION') ?: 'general'
  slurm_account = System.getenv('SLURM_ACCOUNT')
  slurm_args = null
}

cleanup = true

profiles {
  slurm {
    executor {
      account = params.slurm_account
      submitRateLimit = '10/1sec'
      queueSize = 2
      pollInterval = 60.sec
      dumpInterval = 10.min
      queueStatInterval = 60.sec
    }

    process {
      queue = params.slurm_partition
      executor = 'slurm'
      scratch = false
      stageInMode = 'symlink'
      stageOutMode = 'rsync'
      errorStrategy = { (task.exitStatus in [143, 137, 135, 104, 134, 139, 140] || task.exitStatus == null) ? 'retry' : 'finish' }
      maxRetries    = 3
      
	clusterOptions = {
        def args = []
        // args.push("--nodelist=influ4")
        args.push("--output=/home/nfs/alexdelossanto/Dataset_fusion_Microarray/logs_nextflow/${task.name.replaceAll('[^a-zA-Z0-9_-]', '_')}_%j.out")
        args.push("--error=/home/nfs/alexdelossanto/Dataset_fusion_Microarray/logs_nextflow/${task.name.replaceAll('[^a-zA-Z0-9_-]', '_')}_%j.err")
        args.push("--tmp=800000M")

        // Dynamically assign QoS based on the task's max run time from the table
        if (task.time) {
            if (task.time <= 4.hours) {
                args.push("--qos=short")
            } else if (task.time <= 36.hours) { // 1 ½ days = 36 hours
                args.push("--qos=medium")
            } else if (task.time <= 7.days) {
                args.push("--qos=long")
            } else {
                args.push("--qos=infinite")
            }
        } else {
            // Default fallback QoS if a process doesn't explicitly specify a time directive
            args.push("--qos=short")
        }

        if (task.accelerator != null && task.accelerator.type == 'gpu') {
          args.push("--gres=gpu:${task.accelerator.request}")
        }

        if (params.slurm_args != null) {
          args.push(params.slurm_args)
        }
        
        args.join(" ")
      }

      resourceLimits = [time: 7.d, cpus: 64, memory: 1000.GB]
      // ---------------------------------------------------------------
      // FALLBACK: applies to any process not matched by a withName below
      // These are the original conservative limits from the old config.
      // ---------------------------------------------------------------
      withName: '.*' {
        time   = { 1.h   * task.attempt }
        memory = { 3.GB  * task.attempt }
        cpus   = 1
      }
      // ---------------------------------------------------------------
      // TUNED RESOURCE ALLOCATIONS
      // ---------------------------------------------------------------

      // TRIMGALORE: Lowered to 2 CPUs to minimize aggregate core usage
      withName: 'NFCORE_RNASEQ:RNASEQ:FASTQ_FASTQC_UMITOOLS_TRIMGALORE:TRIMGALORE' {
          scratch = false
          time   = { 3.h  * task.attempt }
          memory = { 16.GB * task.attempt }
          cpus   = 2
      }
      
      // FQ_SUBSAMPLE: Tiny footprint stream tool
      withName: 'NFCORE_RNASEQ:RNASEQ:FASTQ_SUBSAMPLE_FQ_SALMON:FQ_SUBSAMPLE' {
        time   = { 1.h   * task.attempt }
        memory = { 500.MB * task.attempt }
        cpus   = 1
      }
      
      // SALMON_QUANT (subsampling step)
      withName: 'NFCORE_RNASEQ:RNASEQ:FASTQ_SUBSAMPLE_FQ_SALMON:SALMON_QUANT' {
          scratch = false
          time   = { 30.m * task.attempt }
          memory = { 5.GB * task.attempt }
          cpus   = 2
          maxForks = 1
      }

      // SALMON_QUANT (main quantification step): Balanced resource profile 
      // Scales gracefully on subsequent retry attempts if a massive sample timeouts.
      withName: 'NFCORE_RNASEQ:RNASEQ:QUANTIFY_PSEUDO_ALIGNMENT:SALMON_QUANT' {
        scratch = false
        maxForks = 1
        time   = { 2.h * task.attempt }
        memory = { 8.GB * task.attempt }
        cpus   = 8
      }
      
      // PREPARE_GENOME steps
      withName: 'NFCORE_RNASEQ:RNASEQ:PREPARE_GENOME:GTF2BED' {
        time   = { 10.m * task.attempt }
        memory = { 2.GB * task.attempt }
        cpus   = 1
      }
      withName: 'NFCORE_RNASEQ:RNASEQ:PREPARE_GENOME:GTF_FILTER' {
        time   = { 15.m * task.attempt }
        memory = { 2.GB * task.attempt }
        cpus   = 1
      }
      withName: 'NFCORE_RNASEQ:RNASEQ:PREPARE_GENOME:CUSTOM_GETCHROMSIZES' {
        time   = { 15.m * task.attempt }
        memory = { 2.GB * task.attempt }
        cpus   = 1
      }
      withName: 'NFCORE_RNASEQ:RNASEQ:PREPARE_GENOME:MAKE_TRANSCRIPTS_FASTA' {
        time   = { 30.m * task.attempt }
        memory = { 2.GB * task.attempt }
        cpus   = 1
      }

      // TXIMPORT + DESEQ2
      withName: 'NFCORE_RNASEQ:RNASEQ:QUANTIFY_PSEUDO_ALIGNMENT:TXIMPORT' {
        time   = { 20.m * task.attempt }
        memory = { 3.GB * task.attempt }
        cpus   = 1
      }
      withName: 'NFCORE_RNASEQ:RNASEQ:DESEQ2_QC_PSEUDO:DESEQ2_QC' {
        time   = { 30.m * task.attempt }
        memory = { 6.GB * task.attempt }
        cpus   = 1
      }
      withName: 'NFCORE_RNASEQ:RNASEQ:PREPARE_GENOME:.*' {
        scratch = false
        time   = { 30.m * task.attempt }
        memory = { 4.GB * task.attempt }
        cpus   = 1
      }
    }
  }
}
// Tell Nextflow to use Apptainer as the container engine
// apptainer {
//     enabled = true
//     autoMounts = true
    
//     // Bind your storage so the container can read/write your data
//     // This replaces the manual --bind you were trying to do earlier
//     runOptions = '--bind /tudelft.net/staff-umbrella:/tudelft.net/staff-umbrella'
// }
singularity {
    enabled = true
    autoMounts = true
    cacheDir = '/home/nfs/alexdelossanto/singularity_cache'
    runOptions = '--bind /tudelft.net/staff-umbrella:/tudelft.net/staff-umbrella/GeneExpressionStorage'
}
// singularity {
//   enabled = true
//   autoMounts = true
//   runOptions = '-e'
// }
// ════════════════════════════════════════════════════════════════════════
// FIX FOR NFS FILE LOCK CRASH (java.nio.file.FileAlreadyExistsException)
// ════════════════════════════════════════════════════════════════════════
timeline.enabled = false
report.enabled = false
trace.enabled = false