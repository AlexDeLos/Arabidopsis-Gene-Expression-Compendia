Bootstrap: docker
From: pytorch/pytorch:2.7.0-cuda12.8-cudnn9-devel

%labels
    Author      alexdelossanto
    Project     Dataset_Fusion_and_BulkFormer
    Python      3.11
    CUDA        12.8
    PyTorch     2.7.0

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export NUMBA_CACHE_DIR=/tmp
    export PATH="/usr/local/bin:$PATH"
    export R_LIBS_USER=/opt/R_libs
    export HF_HOME=/home/user/.cache/huggingface
    export TRANSFORMERS_CACHE=$HF_HOME
    export MPLCONFIGDIR=/tmp/matplotlib

%post
    export DEBIAN_FRONTEND=noninteractive
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

    # =========================================================================
    # 1. System dependencies + R 4.4 (from CRAN, not Ubuntu's outdated r-base)
    # =========================================================================
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        curl \
        gnupg \
        ca-certificates \
        software-properties-common

    # Add CRAN repository for R 4.4 (Ubuntu 22.04 / jammy)
    wget -qO- https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc \
        | gpg --dearmor -o /usr/share/keyrings/r-project.gpg
    echo "deb [signed-by=/usr/share/keyrings/r-project.gpg] https://cloud.r-project.org/bin/linux/ubuntu jammy-cran44/" \
        > /etc/apt/sources.list.d/r-project.list

    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        locales \
        gcc \
        g++ \
        gfortran \
        make \
        r-base \
        r-base-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libfontconfig1-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libtiff5-dev \
        libjpeg-dev \
        libgmp-dev \
        libmpfr-dev \
        libbz2-dev \
        liblzma-dev \
        zlib1g-dev \
        libffi-dev \
        liblapack-dev \
        libblas-dev \
        gzip \
        sra-toolkit \
        && rm -rf /var/lib/apt/lists/*

    # =========================================================================
    # 2. R packages — all installed via R itself for version consistency
    # =========================================================================
    mkdir -p /opt/R_libs
    Rscript -e "
      options(repos=c(CRAN='https://cloud.r-project.org'))
      install.packages('BiocManager', lib='/opt/R_libs', quiet=TRUE)
      library(BiocManager, lib.loc='/opt/R_libs')
      BiocManager::install(
        c('Biobase', 'oligo', 'limma', 'sva'),
        lib='/opt/R_libs',
        ask=FALSE,
        update=FALSE
      )
      install.packages('writexl', lib='/opt/R_libs', quiet=TRUE)
    "

    # =========================================================================
    # 3. Upgrade Pip & Install PyG (Graph) Dependencies
    # =========================================================================
    pip install --no-cache-dir --upgrade pip setuptools wheel

    # Force reinstall torch from PyPI index which includes sm_120,
    # overwriting the Docker image's torch that was compiled without it
    pip install --no-cache-dir --force-reinstall \
        torch==2.7.0 \
        --index-url https://download.pytorch.org/whl/cu128
    pip install --no-cache-dir torch_geometric
    pip install --no-cache-dir pyg_lib torch_scatter torch_sparse \
        -f https://data.pyg.org/whl/torch-2.7.0+cu128.html

    # =========================================================================
    # 4. Data Science, Bioinformatics, and ML Dependencies
    # =========================================================================
    # IMPORTANT: torch is intentionally NOT listed here.
    # The base image provides torch 2.7.0 with sm_120 (Blackwell) support.
    # Re-pinning torch via pip replaces it with a CPU-only wheel.
    pip install --no-cache-dir \
        "numpy<2.0.0" \
        pandas \
        scipy \
        gseapy \
        matplotlib \
        plotly \
        seaborn \
        scikit-learn \
        umap-learn \
        tqdm \
        einops \
        "axial-positional-embedding>=0.1.0" \
        "local-attention>=1.1.1" \
        polars \
        python-dotenv \
        openai \
        debugpy \
        sentence-transformers \
        spacy \
        transformers \
        huggingface-hub \
        biopython \
        GEOparse \
        mygene \
        wandb \
        goatools \
        "rpy2==3.5.16"

    # Download SpaCy language model
    python -m spacy download en_core_web_sm

    # =========================================================================
    # 5. Build-isolated packages (Performer)
    # =========================================================================
    # --no-build-isolation lets performer-pytorch see the installed torch
    # during its C++ compilation step
    pip install --no-cache-dir --no-build-isolation performer-pytorch

%runscript
    exec python "$@"

%test
    python --version
    Rscript --version

    python -c "
import sklearn, numpy, torch, pandas, matplotlib, umap, gseapy
import GEOparse, Bio, tqdm, rpy2, mygene, plotly, goatools, ftplib
from sentence_transformers import SentenceTransformer
import torch_geometric
from torch_sparse import SparseTensor
from performer_pytorch import Performer

print('PyTorch:', torch.__version__)
print('CUDA available:', torch.cuda.is_available())
if torch.cuda.is_available():
    print('CUDA device:', torch.cuda.get_device_name(0))
    print('CUDA capability:', torch.cuda.get_device_capability())
    print('Arch list:', torch.cuda.get_arch_list())
    assert 'sm_120' in torch.cuda.get_arch_list(), \
        'sm_120 not in arch list — Blackwell GPU will not work!'

# Verify SparseTensor works (tests CUDA .so loaded properly)
ei = torch.zeros(2, 4, dtype=torch.long)
ew = torch.ones(4)
st = SparseTensor(row=ei[0], col=ei[1], value=ew, sparse_sizes=(3, 3))
print('SparseTensor: OK')
print('All Python imports OK')
"

    Rscript -e "
      .libPaths(c('/opt/R_libs', .libPaths()))
      suppressMessages({
        library(Biobase)
        library(oligo)
        library(limma)
        library(sva)
        library(writexl)
      })
      cat('All R imports OK\n')
    "
